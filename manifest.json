{
  "manifest_version": 3,
  "name": "Salesforce LogHunt",
  "version": "4.2",
  "description": "Premium Salesforce Debug Log Searcher.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Open Salesforce LogHunt",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "*://*.salesforce.com/*",
    "*://*.force.com/*",
    "*://*.salesforce-setup.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon16.png", "icon48.png", "icon128.png", "bridge.js"],
      "matches": [
        "*://*.salesforce.com/*",
        "*://*.force.com/*",
        "*://*.salesforce-setup.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
