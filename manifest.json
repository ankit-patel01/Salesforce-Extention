{
  "manifest_version": 3,
  "name": "Salesforce LogHunt",
  "version": "4.1",
  "description": "Premium Salesforce Debug Log Searcher.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "Open Salesforce LogHunt",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.salesforce.com/*",
    "*://*.force.com/*",
    "*://*.salesforce-setup.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icon16.png", "icon48.png", "icon128.png"],
      "matches": ["*://*.salesforce.com/*", "*://*.force.com/*", "*://*.salesforce-setup.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
  
}